    <script type="application/ld+json">{"mainEntity":{"headline":"Topological quantum materials for energy conversion and storage","description":"Topological quantum materials (TQMs) have symmetry-protected band structures with useful electronic properties that have applications in information, sensing, energy and other technologies. In the past 10 years, applications of TQMs in the fields of energy conversion and storage, including water splitting, ethanol electro-oxidation, batteries, supercapacitors and relative energy-efficient devices, have attracted increasing attention. The quantum states in TQMs provide a stable electron bath with high electronic conductivity and carrier mobility, long lifetime and readily determined spin states, making TQMs an ideal platform for understanding surface reactions and looking for highly efficient materials for energy conversion and storage. In this Perspective, we present an overview of recent progress in topological quantum catalysis. We describe the open problems and the potential applications of TQMs in water splitting, batteries, supercapacitors and other prospects in energy conversion and storage. Topological quantum materials host protected, high-mobility surface states which can be used for energy conversion and storage. This Perspective discusses recent progress in using topological materials for water splitting, batteries and supercapacitors.","datePublished":"2022-07-11T00:00:00Z","dateModified":"2022-07-11T00:00:00Z","pageStart":"611","pageEnd":"624","sameAs":"https://doi.org/10.1038/s42254-022-00477-9","keywords":["Materials for energy and catalysis","Topological matter","Physics","general"],"image":["https://media.springernature.com/lw1200/springer-static/image/art%3A10.1038%2Fs42254-022-00477-9/MediaObjects/42254_2022_477_Figa_HTML.png","https://media.springernature.com/lw1200/springer-static/image/art%3A10.1038%2Fs42254-022-00477-9/MediaObjects/42254_2022_477_Fig1_HTML.png","https://media.springernature.com/lw1200/springer-static/image/art%3A10.1038%2Fs42254-022-00477-9/MediaObjects/42254_2022_477_Fig2_HTML.png","https://media.springernature.com/lw1200/springer-static/image/art%3A10.1038%2Fs42254-022-00477-9/MediaObjects/42254_2022_477_Fig3_HTML.png","https://media.springernature.com/lw1200/springer-static/image/art%3A10.1038%2Fs42254-022-00477-9/MediaObjects/42254_2022_477_Fig4_HTML.png"],"isPartOf":{"name":"Nature Reviews Physics","issn":["2522-5820"],"volumeNumber":"4","@type":["Periodical","PublicationVolume"]},"publisher":{"name":"Nature Publishing Group UK","logo":{"url":"https://www.springernature.com/app-sn/public/images/logo-springernature.png","@type":"ImageObject"},"@type":"Organization"},"author":[{"name":"Huixia Luo","url":"http://orcid.org/0000-0003-2703-5660","affiliation":[{"name":"Sun Yat-Sen University","address":{"name":"School of Materials Science and Engineering, State Key Laboratory of Optoelectronic Materials and Technologies, Key Laboratory of Polymer Composite & Functional Materials, Guangzhou Key Laboratory of Flexible Electronic Materials and Wearable Devices, Sun Yat-Sen University, Guangzhou, China","@type":"PostalAddress"},"@type":"Organization"}],"email":"luohx7@mail.sysu.edu.cn","@type":"Person"},{"name":"Peifeng Yu","affiliation":[{"name":"Sun Yat-Sen University","address":{"name":"School of Materials Science and Engineering, State Key Laboratory of Optoelectronic Materials and Technologies, Key Laboratory of Polymer Composite & Functional Materials, Guangzhou Key Laboratory of Flexible Electronic Materials and Wearable Devices, Sun Yat-Sen University, Guangzhou, China","@type":"PostalAddress"},"@type":"Organization"}],"@type":"Person"},{"name":"Guowei Li","url":"http://orcid.org/0000-0003-1837-3967","affiliation":[{"name":"Chinese Academy of Sciences","address":{"name":"CAS Key Laboratory of Magnetic Materials and Devices, Zhejiang Province Key Laboratory of Magnetic Materials and Application Technology, Ningbo Institute of Materials Technology and Engineering, Chinese Academy of Sciences, Ningbo, China","@type":"PostalAddress"},"@type":"Organization"},{"name":"University of Chinese Academy of Sciences","address":{"name":"University of Chinese Academy of Sciences, Beijing, China","@type":"PostalAddress"},"@type":"Organization"}],"email":"liguowei@nimte.ac.cn","@type":"Person"},{"name":"Kai Yan","url":"http://orcid.org/0000-0001-9001-6337","affiliation":[{"name":"Sun Yat-Sen University","address":{"name":"School of Environmental Science and Engineering, Sun Yat-Sen University, Guangzhou, China","@type":"PostalAddress"},"@type":"Organization"}],"email":"yank9@mail.sysu.edu.cn","@type":"Person"}],"isAccessibleForFree":false,"hasPart":{"isAccessibleForFree":false,"cssSelector":".main-content","@type":"WebPageElement"},"@type":"ScholarlyArticle"},"@context":"https://schema.org","@type":"WebPage"}</script>




    
    
    


    
